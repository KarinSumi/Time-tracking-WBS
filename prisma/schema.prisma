generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id         String         @id @default(uuid())
  name       String
  parentId   String?
  brandColor String         @default("#3b82f6")
  logoUrl    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  holidays   Holiday[]
  parent     Organization?  @relation("OrgToOrg", fields: [parentId], references: [id])
  children   Organization[] @relation("OrgToOrg")
  phases     Phase[]
  projects   Project[]
  users      User[]
}

model User {
  id            String        @id @default(uuid())
  email         String        @unique
  name          String?
  avatarUrl     String?
  passwordHash  String
  orgId         String
  role          String        @default("USER")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  auditLogs     AuditLog[]
  createdPlans  PlannedTask[] @relation("CreatedPlans")
  assignedPlans PlannedTask[] @relation("AssignedTasks")
  timeEntries   TimeEntry[]
  organization  Organization  @relation(fields: [orgId], references: [id])
}

model Project {
  id           String        @id @default(uuid())
  name         String
  color        String        @default("#3b82f6")
  status       String        @default("ACTIVE")
  orgId        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  plannedTasks PlannedTask[]
  organization Organization  @relation(fields: [orgId], references: [id])
  timeEntries  TimeEntry[]
}

model Phase {
  id           String        @id @default(uuid())
  name         String
  sortOrder    Int           @default(0)
  orgId        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  organization Organization  @relation(fields: [orgId], references: [id])
  plannedTasks PlannedTask[]
  timeEntries  TimeEntry[]
}

model PlannedTask {
  id                 String        @id @default(uuid())
  assigneeId         String
  assignedById       String
  projectId          String?
  phaseId            String?
  wbsId              String?
  parentId           String?
  taskDescription    String
  plannedHours       Decimal
  startDate          DateTime
  endDate            DateTime
  progressPercentage Float         @default(0)
  status             String        @default("PENDING")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  parent             PlannedTask?  @relation("TaskHierarchy", fields: [parentId], references: [id])
  subTasks           PlannedTask[] @relation("TaskHierarchy")
  phase              Phase?        @relation(fields: [phaseId], references: [id])
  project            Project?      @relation(fields: [projectId], references: [id])
  assignedBy         User          @relation("CreatedPlans", fields: [assignedById], references: [id])
  assignee           User          @relation("AssignedTasks", fields: [assigneeId], references: [id])
  timeEntries        TimeEntry[]
}

model TimeEntry {
  id              String       @id @default(uuid())
  userId          String
  projectId       String?
  phaseId         String?
  plannedTaskId   String?
  date            DateTime
  hours           Decimal
  taskDescription String
  status          String       @default("DRAFT")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  plannedTask     PlannedTask? @relation(fields: [plannedTaskId], references: [id])
  phase           Phase?       @relation(fields: [phaseId], references: [id])
  project         Project?     @relation(fields: [projectId], references: [id])
  user            User         @relation(fields: [userId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  action      String
  performedBy String
  oldValues   Json?
  newValues   Json?
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [performedBy], references: [id])
}

model Holiday {
  id           String       @id @default(uuid())
  date         DateTime
  description  String
  orgId        String
  organization Organization @relation(fields: [orgId], references: [id])
}
